{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "@plannotator/opencode@latest"
    ],
    "mcp": {
        "sequential-thinking": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ],
            "enabled": true,
        },
        "supabase": {
            "type": "remote",
            "url": "https://mcp.supabase.com/mcp",
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "command": [
                "npx",
                "y",
                "@upstash/context7-mcp@latest"
            ],
            "enabled": true
        }
    }
}