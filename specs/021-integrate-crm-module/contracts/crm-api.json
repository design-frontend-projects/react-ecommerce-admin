{
  "openapi": "3.1.0",
  "info": {
    "title": "POS & ResPOS CRM Module Integration API",
    "version": "1.0.0",
    "description": "Endpoints to manage contacts, lead pipeline tracking, user tasks, interaction logs, and transactional sync interfaces."
  },
  "paths": {
    "/api/crm/contacts": {
      "get": {
        "summary": "Retrieve paginated CRM customer profiles",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "segment",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CustomerProfile" }
                    },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/crm/leads": {
      "post": {
        "summary": "Capture and create a new CRM lead",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LeadInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lead created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lead_id": { "type": "integer" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/crm/opportunities": {
      "post": {
        "summary": "Progress opportunity pipeline deal stage",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["opportunity_id", "stage"],
                "properties": {
                  "opportunity_id": { "type": "integer" },
                  "stage": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Opportunity updated successfully" }
        }
      }
    },
    "/api/crm/sync-transaction": {
      "post": {
        "summary": "Webhook receiver for POS / ResPOS order completion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["order_id", "transaction_id", "total_amount"],
                "properties": {
                  "order_id": { "type": "string" },
                  "transaction_id": { "type": "string" },
                  "total_amount": { "type": "number" },
                  "customer_email": { "type": "string" },
                  "customer_phone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Transaction synced successfully" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CustomerProfile": {
        "type": "object",
        "properties": {
          "customer_id": { "type": "integer" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "loyalty_points": { "type": "integer" },
          "crm_status": { "type": "string" }
        }
      },
      "LeadInput": {
        "type": "object",
        "required": ["first_name", "last_name", "source"],
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    }
  }
}
