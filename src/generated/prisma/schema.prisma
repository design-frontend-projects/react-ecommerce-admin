generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activity_types {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String       @unique @db.VarChar(50)
  name        String       @db.VarChar(100)
  description String?
  is_active   Boolean      @default(true)
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  audit_logs  audit_logs[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id       String         @db.Uuid
  activity_type_id String         @db.Uuid
  action           String         @db.VarChar(255)
  entity_type      String         @db.VarChar(100)
  entity_id        String         @db.VarChar(100)
  old_values       Json?
  new_values       Json?
  metadata         Json?
  ip_address       String?        @db.VarChar(45)
  user_agent       String?
  created_at       DateTime?      @default(now()) @db.Timestamp(6)
  activity_types   activity_types @relation(fields: [activity_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles         profiles       @relation(fields: [profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([activity_type_id], map: "idx_audit_logs_activity_type_id")
  @@index([created_at], map: "idx_audit_logs_created_at")
  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
  @@index([profile_id], map: "idx_audit_logs_profile_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model branches {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                  @db.VarChar(200)
  city_id               String                  @db.Uuid
  address               String?
  phone                 String?                 @db.VarChar(20)
  is_active             Boolean?                @default(true)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  auth_user_id          String?                 @db.Uuid
  cities                cities                  @relation(fields: [city_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventory_movements   inventory_movements[]
  profiles              profiles[]
  purchase_invoices     purchase_invoices[]
  purchase_orders       purchase_orders[]
  purchase_requisitions purchase_requisitions[]
  purchase_returns      purchase_returns[]
  refunds               refunds[]
  res_shifts            res_shifts[]
  sales_invoices        sales_invoices[]
  sales_orders          sales_orders[]
  sales_returns         sales_returns[]
  stock_transfers_from  stock_transfers[]       @relation("stock_transfers_from_branch")
  stock_transfers_to    stock_transfers[]       @relation("stock_transfers_to_branch")
  stores                stores[]

  @@index([city_id], map: "idx_branches_city_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  category_id  Int            @id @default(autoincrement())
  name         String         @db.VarChar(100)
  description  String?
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  auth_user_id String?        @db.Uuid
  is_active    Boolean?       @default(true)
  products     products[]
  stock_counts stock_counts[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cities {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String      @db.VarChar(100)
  country_id String      @db.Uuid
  is_active  Boolean?    @default(true)
  created_at DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at DateTime?   @default(now()) @db.Timestamptz(6)
  branches   branches[]
  countries  countries   @relation(fields: [country_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stores     stores[]
  suppliers  suppliers[]

  @@unique([name, country_id])
  @@index([country_id], map: "idx_cities_country_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model countries {
